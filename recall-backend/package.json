    "db:diff": "supabase db diff",
    "gen:types": "supabase gen types typescript --local > ../src/services/generated/database.types.ts",
    "fn:serve": "supabase functions serve",
    "fn:deploy": "supabase functions deploy",
    "link": "supabase link"
  }
}
