{
  "name": "recall-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Recall backend — Supabase (Postgres, Auth, Storage, Edge Functions). Independent of the app; the frontend talks to it only over HTTPS.",
  "scripts": {
    "db:start": "supabase start",
