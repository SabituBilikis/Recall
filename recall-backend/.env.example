# Recall backend — copy to .env and fill in. NEVER commit .env.
# These belong to the BACKEND only. The service-role key must never reach the app.

# Hosted project (from the Supabase dashboard → Project Settings → API)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Values the FRONTEND needs (safe to expose) live in the app's own .env instead:
#   EXPO_PUBLIC_SUPABASE_URL
#   EXPO_PUBLIC_SUPABASE_ANON_KEY
