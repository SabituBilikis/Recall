# Recall app environment.
# Copy to .env and fill in. Values come from your Supabase project
# (Dashboard -> Project Settings -> API). The publishable/anon key is safe in the
# client — RLS is the real authorization. NEVER put the service-role key here.

# Hosted Supabase project URL, e.g. https://abcdxyz.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# "Publishable" key (formerly "anon"). Either name is read by the client.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Turn the real backend on (false / unset = mock mode).
EXPO_PUBLIC_USE_BACKEND=true
