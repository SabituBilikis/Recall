{
  "expo": {
    "name": "Recall",
    "slug": "recall",
    "scheme": "recall",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.recall.app"
    },
    "android": {
      "package": "com.recall.app",
      "adaptiveIcon": {
        "backgroundColor": "#F3F1FF",
        "foregroundImage": "./assets/adaptive-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "image": "./assets/recall-logo-mark.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F3F1FF"
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Recall to access your photos to set your profile picture."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true,
            "useLegacyPackaging": true
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "02a5000c-16d2-4c38-a541-e5ffb61b6d11"
      }
    },
    "owner": "bilqees",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/02a5000c-16d2-4c38-a541-e5ffb61b6d11"
    }
  }
}
