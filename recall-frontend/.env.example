# Recall app environment.
# Copy to .env and fill in. Values come from your Supabase project
# (Dashboard -> Project Settings -> API). The publishable/anon key is safe in the
# client — RLS is the real authorization. NEVER put the service-role key here.

# Hosted Supabase project URL, e.g. https://abcdxyz.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# "Publishable" key (formerly "anon"). Either name is read by the client.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Turn the real backend on (false / unset = mock mode).
EXPO_PUBLIC_USE_BACKEND=true

# Sentry source-map upload token (build-time only, SECRET). Get from Sentry ->
# Settings -> Auth Tokens (scopes: project:releases, org:read). Only needed for
# readable release stack traces; the app reports crashes without it. For EAS
# cloud builds add it as an EAS secret, not in eas.json.
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# PostHog product analytics (client-safe project key). Without a key, analytics
# stays a no-op. Get it from PostHog -> Project Settings -> Project API Key.
EXPO_PUBLIC_POSTHOG_KEY=your-posthog-project-key
# Optional — defaults to https://us.i.posthog.com (use https://eu.i.posthog.com for EU).
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
